<?xml version="1.0" encoding="UTF-8"?>
<!--
    Traditional Java 7 Web Application Deployment Descriptor
    
    This web.xml configuration demonstrates classic enterprise Java servlet patterns
    commonly found in legacy applications before Spring Boot auto-configuration.
    
    Migration Opportunities:
    - Manual servlet configuration -> Spring Boot auto-configuration
    - web.xml deployment descriptor -> Java-based configuration (@Configuration)
    - Individual servlet mappings -> Spring @RestController annotations
    - Manual filter configuration -> Spring Security configuration
    - Traditional servlet context -> Spring ApplicationContext
    - Manual CORS configuration -> Spring @CrossOrigin annotations
    - Basic error pages -> Spring @ControllerAdvice exception handling
    
    Business Context:
    - Configures REST API endpoints for Music Library management
    - Maps URL patterns to individual servlet handlers
    - Provides traditional enterprise Java web application structure
    - Supports CRUD operations for Songs, Artists, Albums, and Playlists
    - Includes basic error handling and CORS support for web clients
-->
<web-app xmlns="http://java.sun.com/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://java.sun.com/xml/ns/javaee 
         http://java.sun.com/xml/ns/javaee/web-app_3_0.xsd"
         version="3.0">

    <!-- Application Metadata -->
    <display-name>Music Library API</display-name>
    <description>
        Legacy Java 7 Music Library REST API
        Demonstrates traditional enterprise Java patterns for migration to modern Java
    </description>

    <!-- Context Parameters for Application Configuration -->
    <context-param>
        <param-name>database.config.location</param-name>
        <param-value>/database.properties</param-value>
        <description>Database configuration properties file location</description>
    </context-param>

    <context-param>
        <param-name>api.version</param-name>
        <param-value>1.0</param-value>
        <description>API version for client compatibility</description>
    </context-param>

    <context-param>
        <param-name>cors.enabled</param-name>
        <param-value>true</param-value>
        <description>Enable CORS support for web clients</description>
    </context-param>

    <!-- Song Management Servlet Configuration -->
    <servlet>
        <servlet-name>SongServlet</servlet-name>
        <servlet-class>com.musiclibrary.servlet.SongServlet</servlet-class>
        <description>Handles CRUD operations for Song entities</description>
        <load-on-startup>1</load-on-startup>
        
        <!-- Servlet-specific initialization parameters -->
        <init-param>
            <param-name>entity.type</param-name>
            <param-value>Song</param-value>
        </init-param>
        <init-param>
            <param-name>max.page.size</param-name>
            <param-value>100</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>SongServlet</servlet-name>
        <url-pattern>/api/songs</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>SongServlet</servlet-name>
        <url-pattern>/api/songs/*</url-pattern>
    </servlet-mapping>

    <!-- Artist Management Servlet Configuration -->
    <servlet>
        <servlet-name>ArtistServlet</servlet-name>
        <servlet-class>com.musiclibrary.servlet.ArtistServlet</servlet-class>
        <description>Handles CRUD operations for Artist entities</description>
        <load-on-startup>2</load-on-startup>
        
        <init-param>
            <param-name>entity.type</param-name>
            <param-value>Artist</param-value>
        </init-param>
        <init-param>
            <param-name>max.page.size</param-name>
            <param-value>50</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>ArtistServlet</servlet-name>
        <url-pattern>/api/artists</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>ArtistServlet</servlet-name>
        <url-pattern>/api/artists/*</url-pattern>
    </servlet-mapping>

    <!-- Album Management Servlet Configuration -->
    <servlet>
        <servlet-name>AlbumServlet</servlet-name>
        <servlet-class>com.musiclibrary.servlet.AlbumServlet</servlet-class>
        <description>Handles CRUD operations for Album entities</description>
        <load-on-startup>3</load-on-startup>
        
        <init-param>
            <param-name>entity.type</param-name>
            <param-value>Album</param-value>
        </init-param>
        <init-param>
            <param-name>max.page.size</param-name>
            <param-value>50</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>AlbumServlet</servlet-name>
        <url-pattern>/api/albums</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>AlbumServlet</servlet-name>
        <url-pattern>/api/albums/*</url-pattern>
    </servlet-mapping>

    <!-- Playlist Management Servlet Configuration -->
    <servlet>
        <servlet-name>PlaylistServlet</servlet-name>
        <servlet-class>com.musiclibrary.servlet.PlaylistServlet</servlet-class>
        <description>Handles CRUD operations for Playlist entities</description>
        <load-on-startup>4</load-on-startup>
        
        <init-param>
            <param-name>entity.type</param-name>
            <param-value>Playlist</param-value>
        </init-param>
        <init-param>
            <param-name>max.page.size</param-name>
            <param-value>25</param-value>
        </init-param>
    </servlet>

    <servlet-mapping>
        <servlet-name>PlaylistServlet</servlet-name>
        <url-pattern>/api/playlists</url-pattern>
    </servlet-mapping>
    
    <servlet-mapping>
        <servlet-name>PlaylistServlet</servlet-name>
        <url-pattern>/api/playlists/*</url-pattern>
    </servlet-mapping>

    <!-- Health Check and Status Servlet -->
    <servlet>
        <servlet-name>HealthCheckServlet</servlet-name>
        <servlet-class>com.musiclibrary.servlet.HealthCheckServlet</servlet-class>
        <description>Provides API health check and status information</description>
        <load-on-startup>5</load-on-startup>
    </servlet>

    <servlet-mapping>
        <servlet-name>HealthCheckServlet</servlet-name>
        <url-pattern>/api/health</url-pattern>
    </servlet-mapping>

    <servlet-mapping>
        <servlet-name>HealthCheckServlet</servlet-name>
        <url-pattern>/api/status</url-pattern>
    </servlet-mapping>

    <!-- CORS Filter Configuration -->
    <filter>
        <filter-name>CorsFilter</filter-name>
        <filter-class>com.musiclibrary.filter.CorsFilter</filter-class>
        <description>Handles Cross-Origin Resource Sharing for web clients</description>
        
        <init-param>
            <param-name>cors.allowed.origins</param-name>
            <param-value>*</param-value>
        </init-param>
        <init-param>
            <param-name>cors.allowed.methods</param-name>
            <param-value>GET,POST,PUT,DELETE,OPTIONS</param-value>
        </init-param>
        <init-param>
            <param-name>cors.allowed.headers</param-name>
            <param-value>Content-Type,Authorization,X-Requested-With</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>CorsFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Request Logging Filter -->
    <filter>
        <filter-name>RequestLoggingFilter</filter-name>
        <filter-class>com.musiclibrary.filter.RequestLoggingFilter</filter-class>
        <description>Logs incoming requests for debugging and monitoring</description>
        
        <init-param>
            <param-name>log.level</param-name>
            <param-value>INFO</param-value>
        </init-param>
        <init-param>
            <param-name>log.request.body</param-name>
            <param-value>false</param-value>
        </init-param>
    </filter>

    <filter-mapping>
        <filter-name>RequestLoggingFilter</filter-name>
        <url-pattern>/api/*</url-pattern>
    </filter-mapping>

    <!-- Session Configuration -->
    <session-config>
        <session-timeout>30</session-timeout>
        <cookie-config>
            <http-only>true</http-only>
            <secure>false</secure>
        </cookie-config>
    </session-config>

    <!-- Welcome File List -->
    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Error Page Configuration -->
    <error-page>
        <error-code>404</error-code>
        <location>/error/404.html</location>
    </error-page>

    <error-page>
        <error-code>500</error-code>
        <location>/error/500.html</location>
    </error-page>

    <error-page>
        <exception-type>java.lang.Throwable</exception-type>
        <location>/error/general.html</location>
    </error-page>

    <!-- Security Constraints (Basic) -->
    <security-constraint>
        <display-name>API Access</display-name>
        <web-resource-collection>
            <web-resource-name>All API Resources</web-resource-name>
            <url-pattern>/api/*</url-pattern>
            <http-method>GET</http-method>
            <http-method>POST</http-method>
            <http-method>PUT</http-method>
            <http-method>DELETE</http-method>
        </web-resource-collection>
        <!-- No auth-constraint means all users can access -->
    </security-constraint>

    <!-- MIME Type Mappings -->
    <mime-mapping>
        <extension>json</extension>
        <mime-type>application/json</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>js</extension>
        <mime-type>application/javascript</mime-type>
    </mime-mapping>

    <mime-mapping>
        <extension>css</extension>
        <mime-type>text/css</mime-type>
    </mime-mapping>

    <!-- Resource References -->
    <resource-ref>
        <description>Music Library Database Connection</description>
        <res-ref-name>jdbc/MusicLibraryDB</res-ref-name>
        <res-type>javax.sql.DataSource</res-type>
        <res-auth>Container</res-auth>
    </resource-ref>

</web-app>
